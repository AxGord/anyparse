package anyparse.grammar.haxe;

import anyparse.format.CommentStyle;
import anyparse.format.IndentChar;
import anyparse.format.WriteOptions;

/**
 * Plugin-level AST transformation for captured block-comment bodies.
 *
 * Lives in the Haxe format plugin package — NOT in the macro core or
 * the generic runtime. Parser and writer are 100% auto-generated by
 * `Build.buildParser` / `Build.buildWriter` and know nothing about
 * Haxe comment conventions; this normalizer is where those
 * conventions live. It runs between parse and write:
 *
 *  raw `/*…*\/` string
 *    → `BlockCommentParser.parse`
 *    → `BlockComment` AST (verbatim, variants distinguished by
 *      source wrap literals; each line is `StarredLine` or `PlainLine`)
 *    → `HaxeCommentNormalizer.normalize` (AST → AST: pick target
 *      variant + per-line variant, normalize ws, fabricate markers)
 *    → `BlockComment` AST (canonical, target variants)
 *    → `BlockCommentWriter.writeDoc`
 *    → `Doc` embedded in the enclosing writer's stream
 *
 * What this class decides (the Haxe-specific rendering policy):
 *
 *  - **Wrap variant**: `opt.commentStyle == Plain` → `BlockComment.Plain`;
 *    `Javadoc` or `JavadocNoStars` → `BlockComment.DoubleStars`.
 *    Wrap literals (`/*` / `*\/` / `/**` / `**\/`) come from the
 *    enum's `@:lead` / `@:trail` metas — this class never hardcodes
 *    them.
 *  - **Line variant**: for `Javadoc` output → `JavadocLine` /
 *    `JavadocBlankLine` (canonical prefixes declared by
 *    `@:lead(' * ')` / `@:lit(' *')` on those variants in
 *    `BlockCommentLine`); for `JavadocNoStars` / `Plain` → `PlainLine`.
 *  - **Indent canonicalization**: source leading ws is reduced via
 *    common-prefix across non-blank lines; remainder becomes the
 *    relative offset carried into the canonical `ws`. Absolute
 *    indent comes from the writer's `indentChar` / `indentSize`.
 *  - **Inline-first-line exclusion**: `lines[0]` is excluded from
 *    the common-prefix compute when it has non-blank content
 *    (source had `/** foo` inline).
 *  - **Blank-edge skip**: fully-blank first/last captured line
 *    dropped so wrap delimiters sit on their own lines.
 */
class HaxeCommentNormalizer {

	public static function normalize(source:BlockComment, opt:WriteOptions):BlockComment {
		final sourceLines:Array<BlockCommentLine> = switch source {
			case DoubleStars(ls): ls;
			case Plain(ls): ls;
		};
		final canonicalLines:Array<BlockCommentLine> = normalizeLines(sourceLines, opt);
		return switch opt.commentStyle {
			case Plain: BlockComment.Plain(canonicalLines);
			case Javadoc, JavadocNoStars: BlockComment.DoubleStars(canonicalLines);
		};
	}

	private static function normalizeLines(source:Array<BlockCommentLine>, opt:WriteOptions):Array<BlockCommentLine> {
		final withStars:Bool = opt.commentStyle == CommentStyle.Javadoc;
		final indentUnit:String = opt.indentChar == IndentChar.Tab
			? '\t'
			: StringTools.rpad('', ' ', opt.indentSize);

		final firstInline:Bool = source.length > 0
			&& getLineContent(source[0]).length > 0;

		// Common-prefix reduce across non-blank lines' leading ws,
		// excluding line 0 when it's inline with the opening delimiter.
		var commonPrefix:String = '';
		var havePrefix:Bool = false;
		for (i in 0...source.length) {
			if (i == 0 && firstInline) continue;
			if (getLineContent(source[i]).length == 0) continue;
			final ws:String = getLineWs(source[i]);
			if (!havePrefix) {
				commonPrefix = ws;
				havePrefix = true;
			} else {
				final lim:Int = commonPrefix.length < ws.length ? commonPrefix.length : ws.length;
				var j:Int = 0;
				while (j < lim && StringTools.fastCodeAt(commonPrefix, j) == StringTools.fastCodeAt(ws, j)) j++;
				commonPrefix = commonPrefix.substr(0, j);
			}
		}
		final commonLen:Int = commonPrefix.length;

		final result:Array<BlockCommentLine> = [];
		final last:Int = source.length - 1;
		for (i in 0...source.length) {
			final ln:BlockCommentLine = source[i];
			final content:String = getLineContent(ln);
			if ((i == 0 || i == last) && content.length == 0) continue;
			final sourceWs:String = getLineWs(ln);
			final relWs:String = sourceWs.length > commonLen ? sourceWs.substr(commonLen) : '';
			if (withStars) {
				result.push(content.length > 0
					? BlockCommentLine.JavadocLine(relWs + content)
					: BlockCommentLine.JavadocBlankLine);
			} else {
				result.push(BlockCommentLine.PlainLine({
					ws: indentUnit + relWs,
					content: content,
				}));
			}
		}
		return result;
	}

	// The canonical javadoc variants (`JavadocLine` / `JavadocBlankLine`)
	// are never produced by the parser — permissive `StarredLine` /
	// `PlainLine` variants catch everything first, per the declaration
	// order in `BlockCommentLine`. They only appear as normalizer output
	// on the way to the writer, so the helpers below never observe them
	// against source input and can safely reject them.
	private static function getLineWs(ln:BlockCommentLine):String {
		return switch ln {
			case StarredLine(body): body.ws;
			case PlainLine(body): body.ws;
			case JavadocLine(_) | JavadocBlankLine:
				throw 'unreachable: parser does not produce canonical javadoc variants';
		};
	}

	private static function getLineContent(ln:BlockCommentLine):String {
		return switch ln {
			case StarredLine(body): StringTools.rtrim(body.content);
			case PlainLine(body): StringTools.rtrim(body.content);
			case JavadocLine(_) | JavadocBlankLine:
				throw 'unreachable: parser does not produce canonical javadoc variants';
		};
	}
}
