#!/usr/bin/env sh
# `hxq` — Haxe-preset alias for `apq`. Prepends `--lang haxe` to the
# ast/search/… subcommand's options.
#
# Engine dispatch: prefers the JS build `bin/apq.js` (run via node) when
# present — it is ~1.4-2x faster than the neko build on every parsing
# operation (V8 JIT vs neko bytecode; the fixed +22ms node startup is
# absorbed within the first 100ms of real work). Falls back to the neko
# build `bin/apq.n` when the JS build is absent. The neko build remains
# the canonical engine for the self-parse sweep and the test suites;
# this launcher only changes the default for interactive `hxq` use.
#
# Build: `haxe bin/apq-js.hxml` (JS, preferred) and/or
#        `haxe bin/apq.hxml` (neko, canonical for sweep/tests).
#
# Install (optional, for a global `hxq`): symlink this script into a
# PATH dir, e.g. `ln -s "$PWD/bin/hxq" ~/.local/bin/hxq`. The script
# resolves its own real path through symlinks, so it still finds
# `apq.js`/`apq.n` in the repo's bin/ regardless of the symlink location.
#
# Usage: hxq <subcommand> [options] <file>

set -e

# Resolve this script's real path, following symlinks (POSIX `readlink`,
# no `-f` — portable BSD/macOS + Linux). Without this, invoking via a
# symlink would make `here` the symlink's dir, not the repo bin/.
src="$0"
while [ -h "$src" ]; do
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case "$src" in
        /*) ;;
        *) src="$dir/$src" ;;
    esac
done
here=$(cd -P "$(dirname "$src")" && pwd)

# Worktree awareness: when invoked from inside a git worktree (or clone)
# whose own bin/ holds a built engine, prefer THAT engine + its src/ over
# the symlink-resolved one above. Without this, `hxq` run from a campaign
# worktree queries the MAIN tree's apq.js and stale-checks the MAIN src/
# — silently testing the wrong parser (the worktree's grammar edits are
# invisible). Falls back to the symlink-resolved `here` when CWD is
# outside a git tree (e.g. reading a reference library), when the
# worktree's engine isn't built yet, or when CWD is the main tree
# (then $wt_top/bin == $here, no change). `|| true` keeps `set -e` happy
# when git is absent or CWD is not a repo.
wt_top=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -n "$wt_top" ] && [ "$wt_top/bin" != "$here" ] && { [ -f "$wt_top/bin/apq.js" ] || [ -f "$wt_top/bin/apq.n" ]; }; then
    here="$wt_top/bin"
fi

js="$here/apq.js"
nn="$here/apq.n"

if [ -f "$js" ]; then
    runner="node"
    binary="$js"
elif [ -f "$nn" ]; then
    runner="neko"
    binary="$nn"
else
    echo "hxq: neither $js nor $nn found — run \`haxe bin/apq-js.hxml\` (preferred) or \`haxe bin/apq.hxml\`" >&2
    exit 1
fi

# Stale-build handling: if any .hx under src/ is newer than the selected
# binary, the user is invoking an outdated artifact. `find -newer …
# -quit` short-circuits at the first hit (sub-50ms even on cold cache)
# and stays silent when the repo layout doesn't match (e.g. shim copied
# outside the source tree).
#
# UX (default = auto-rebuild):
#   HXQ_QUIET=1         — skip the stale check entirely (no rebuild,
#                         no warning). Takes precedence over the other
#                         envs. Use when the harness is doing its own
#                         build management.
#   HXQ_AUTO_REBUILD=0  — opt OUT of auto-rebuild and fall back to the
#                         legacy warn-once-per-mtime mode. Useful when
#                         interactive feedback on the build itself is
#                         desired (`haxe bin/apq-js.hxml` separately).
#   Otherwise: auto-rebuild runs the appropriate `haxe bin/<hxml>` and
#   aborts on build failure. Stale results are silent regressions —
#   defaulting to auto-rebuild keeps query output truthful without
#   manual rebuilds between grammar edits.
src_root="$here/../src"
if [ "${HXQ_QUIET:-}" != "1" ] && [ -d "$src_root" ]; then
    stale=$(find "$src_root" -name '*.hx' -newer "$binary" -print -quit 2>/dev/null || true)
    if [ -n "$stale" ]; then
        if [ "$runner" = "node" ]; then
            bin_name="bin/apq.js"
            hxml_path="$here/apq-js.hxml"
            hxml_name="bin/apq-js.hxml"
        else
            bin_name="bin/apq.n"
            hxml_path="$here/apq.hxml"
            hxml_name="bin/apq.hxml"
        fi
        if [ "${HXQ_AUTO_REBUILD:-1}" != "0" ]; then
            # Rebuild in-process (DEFAULT). On failure print the build's
            # stderr and bail — running a stale binary after a failed
            # rebuild would be misleading.
            echo "hxq: src/ newer than $bin_name; auto-rebuilding ($hxml_name)..." >&2
            if ! (cd "$here/.." && haxe "$hxml_path") >&2; then
                echo "hxq: auto-rebuild failed; aborting (set HXQ_AUTO_REBUILD=0 for warn-only mode, or HXQ_QUIET=1 to skip the check)" >&2
                exit 1
            fi
        else
            # Legacy warn-only mode (opt-in via HXQ_AUTO_REBUILD=0).
            # mtime-keyed throttle. Portable mtime: `stat` differs
            # across BSD/macOS (`-f %m`) and GNU (`-c %Y`).
            if mtime=$(stat -f %m "$binary" 2>/dev/null); then :
            elif mtime=$(stat -c %Y "$binary" 2>/dev/null); then :
            else mtime="unknown"
            fi
            cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/hxq"
            marker="$cache_dir/warned"
            last=""
            [ -r "$marker" ] && last=$(cat "$marker" 2>/dev/null || true)
            if [ "$last" != "$mtime" ]; then
                echo "hxq: warning: src/ has .hx files newer than $bin_name — run \`haxe $hxml_name\` to rebuild (first stale: $stale)" >&2
                echo "hxq: (silenced for this binary mtime; clear HXQ_AUTO_REBUILD to auto-rebuild, set HXQ_QUIET=1 to disable check)" >&2
                mkdir -p "$cache_dir" 2>/dev/null || true
                printf '%s' "$mtime" > "$marker" 2>/dev/null || true
            fi
        fi
    fi
fi

# With no user args, just run the binary (prints usage); otherwise inject
# `--lang haxe` after the subcommand so `hxq <cmd> [opts] <file>` targets
# the Haxe grammar.
if [ "$#" -eq 0 ]; then
    exec "$runner" "$binary"
fi

cmd="$1"
shift
exec "$runner" "$binary" "$cmd" --lang haxe "$@"
