#!/usr/bin/env sh
# `hxq` — Haxe-preset alias for `apq`. Invokes the neko binary built
# by `haxe bin/apq.hxml` with `--lang haxe` prepended to the ast/search/…
# subcommand's options.
#
# Usage: hxq <subcommand> [options] <file>
#
# Expects `bin/apq.n` to exist relative to this script.

set -e

here=$(cd "$(dirname "$0")" && pwd)
binary="$here/apq.n"

if [ ! -f "$binary" ]; then
    echo "hxq: $binary not found — run \`haxe bin/apq.hxml\` first" >&2
    exit 1
fi

if [ "$#" -eq 0 ]; then
    exec neko "$binary"
fi

cmd="$1"
shift
exec neko "$binary" "$cmd" --lang haxe "$@"
